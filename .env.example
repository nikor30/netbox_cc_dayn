# DayN-NetBox Bridge configuration. Copy to .env and fill in.

# Base URL of your NetBox instance (no trailing slash).
NETBOX_URL=https://netbox.global.web-int.net

# API token. A read-only token is sufficient — the tool never writes to NetBox.
NETBOX_TOKEN=changeme

# Verify NetBox TLS certificate (set to false only for lab instances).
NETBOX_VERIFY_SSL=true

# Port the web GUI listens on.
APP_PORT=8070

# Python logging level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Maximum upload size in bytes (default 2 MB).
UPLOAD_MAX_BYTES=2097152

# How long parsed uploads are kept in memory, in seconds.
SESSION_TTL_SECONDS=3600
